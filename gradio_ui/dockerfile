# 
FROM python:3.11-slim

WORKDIR /app

COPY gradio_ui/requirements.txt /app/gradio_ui/requirements.txt

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r /app/gradio_ui/requirements.txt

COPY . .

EXPOSE 4004

ENV GRADIO_ANALYTICS_ENABLED="False"
ENV PYTHONPATH=/app

CMD ["python", "gradio_ui/app.py"]